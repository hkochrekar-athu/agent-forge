# ─── Auth0 Core (Required) ───────────────────────────────────────────────────
# Get from: Auth0 Dashboard → Applications → Your App → Settings
AUTH0_SECRET='use-openssl-rand-hex-32-to-generate'
AUTH0_BASE_URL='http://localhost:3000'
AUTH0_ISSUER_BASE_URL='https://YOUR_AUTH0_DOMAIN.auth0.com'
AUTH0_CLIENT_ID='your_auth0_client_id'
AUTH0_CLIENT_SECRET='your_auth0_client_secret'

# ─── Auth0 Management API (Token Vault) ──────────────────────────────────────
# Get from: Auth0 Dashboard → Applications → APIs → Auth0 Management API
# Create a Machine-to-Machine app with Management API permissions:
# read:users, update:users
AUTH0_DOMAIN='YOUR_AUTH0_DOMAIN.auth0.com'
AUTH0_MGMT_CLIENT_ID='your_management_app_client_id'
AUTH0_MGMT_CLIENT_SECRET='your_management_app_client_secret'

# ─── Anthropic (Fallback when Token Vault not configured) ────────────────────
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY='sk-ant-...'

# ─── Vercel (auto-set on deploy, update for production) ──────────────────────
# AUTH0_BASE_URL='https://your-app.vercel.app'
